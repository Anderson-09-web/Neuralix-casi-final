modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "cd artifacts/api-server && node --enable-source-maps dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/neuralix run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f 'vite.*vite.config.ts' 2>/dev/null; sleep 1; pnpm --filter @workspace/neuralix run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 3 && fuser -k 8080/tcp 2>/dev/null; sleep 1; pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 23133
externalPort = 3000

[userenv]

[userenv.shared]
OWNER_DISCORD_IDS = "1237892993013387307"
PORT = "5000"
BASE_PATH = "/"

[userenv.production]
APP_URL = "neuralixallow.vercel.app"

[nix]
channel = "stable-25_05"
