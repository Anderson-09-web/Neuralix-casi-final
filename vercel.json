{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/neuralix run build",
  "outputDirectory": "artifacts/neuralix/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://663de9c6-125a-4fbf-b3c0-986713cb1427-00-1ugvr2ze31ql9.worf.replit.dev/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
