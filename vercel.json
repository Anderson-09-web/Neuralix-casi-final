{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/neuralix run build",
  "outputDirectory": "artifacts/neuralix/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REEMPLAZA_CON_TU_URL_REPLIT/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
